{
  "name": "scientific-tangle-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "UI для системы Научный Клубок — доказательная карта R&D знаний горно-металлургической отрасли",
  "scripts": {
    "dev": "vite",
    "dev:mock": "vite --mode mock",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:e2e": "vite build --mode e2e",
    "preview:e2e": "vite preview --port 3000",
    "test": "vitest run",
    "test:e2e": "playwright test --grep @offline",
    "test:e2e:stack": "playwright test --grep @stack",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "html2pdf.js": "^0.14.0",
    "i18next": "^25.5.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-dropzone": "^14.3.8",
    "react-force-graph-2d": "^1.28.0",
    "react-i18next": "^15.4.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.4",
    "recharts": "^3.2.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "tailwind-scrollbar": "^2.1.0",
    "tailwindcss": "^3.4.18",
    "vite": "^7.1.7",
    "vitest": "^3.2.4",
    "@playwright/test": "^1.55.0"
  }
}
