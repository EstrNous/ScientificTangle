POSTGRES_DB=scientific_tangle
POSTGRES_USER=st_user
POSTGRES_PASSWORD=st_pass

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_URL=postgresql+asyncpg://st_user:st_pass@postgres:5432/scientific_tangle

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_pass
NEO4J_AUTH=neo4j/neo4j_pass


QDRANT_URL=http://qdrant:6333


MINIO_ENDPOINT=minio:9000
MINIO_URL=http://minio:9000
MINIO_SECURE=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
SOURCE_BUCKET=source-files
UPLOAD_LIMIT_BYTES=104857600

REDIS_URL=redis://redis:6379/0

RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_PER_MINUTE=120
RATE_LIMIT_TRUST_PROXY_HEADERS=false
RATE_LIMIT_USE_REDIS=true

LOG_LEVEL=INFO

GATEWAY_URL=http://gateway:8000
AUTH_URL=http://auth_audit:8001
ORCHESTRATOR_URL=http://orchestrator:8002
INGESTION_URL=http://ingestion:8003
KNOWLEDGE_URL=http://knowledge:8004
RETRIEVAL_URL=http://retrieval:8005
MODEL_URL=http://model:8006
EXPORT_URL=http://export:8007
NOTIFICATION_URL=http://notification:8008

INTERNAL_SERVICE_TOKEN=change-me-internal-service-token

GATEWAY_PORT=8000
AUTH_AUDIT_PORT=8001
ORCHESTRATOR_PORT=8002
INGESTION_PORT=8003
KNOWLEDGE_PORT=8004
RETRIEVAL_PORT=8005
MODEL_PORT=8006
EXPORT_PORT=8007
NOTIFICATION_PORT=8008

LLM_PROVIDER=yandex
YANDEX_AI_BASE_URL=https://ai.api.cloud.yandex.net/v1
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

YANDEX_CHAT_MODEL=yandexgpt-5.1
YANDEX_FAST_MODEL=yandexgpt-5-lite
YANDEX_LONG_CONTEXT_MODEL=deepseek-v4-flash
YANDEX_MULTILINGUAL_MODEL=qwen3-235b-a22b-fp8
YANDEX_VISION_TEXT_MODEL=qwen3.6-35b-a3b
YANDEX_EMBEDDING_DOC_MODEL=text-embeddings-v2-doc
YANDEX_EMBEDDING_QUERY_MODEL=text-embeddings-v2-query
YANDEX_EMBEDDING_DIM=256
YANDEX_USE_TUNED_EMBEDDINGS=false
YANDEX_TUNED_EMBEDDING_MODEL_URI=

MODEL_REQUEST_TIMEOUT_SECONDS=120
MODEL_TEMPERATURE=0.2
MODEL_MAX_OUTPUT_TOKENS=2000
MODEL_CACHE_BACKEND=redis
MODEL_CACHE_TTL_SECONDS=86400
MODEL_EMBEDDING_CACHE_TTL_SECONDS=604800
MODEL_CACHE_CONNECT_TIMEOUT_SECONDS=0.2

# ===========================
# Auth Service
# ===========================

AUTH_DATABASE_URL=postgresql+asyncpg://st_user:st_pass@postgres:5432/scientific_tangle

AUTH_JWT_PRIVATE_KEY_PATH=/run/secrets/auth_private.pem
AUTH_JWT_PUBLIC_KEY_PATH=/run/secrets/auth_public.pem
AUTH_JWT_PRIVATE_KEY_HOST_PATH=./secrets/auth_private.pem
AUTH_JWT_PUBLIC_KEY_HOST_PATH=./secrets/auth_public.pem

AUTH_JWT_ISSUER=scientific-tangle-auth
AUTH_JWT_AUDIENCE=scientific-tangle-api
AUTH_JWT_KEY_ID=auth-key-1
AUTH_JWKS_CACHE_SECONDS=300
AUTH_CLOCK_SKEW_SECONDS=30

AUTH_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REDIS_URL=redis://redis:6379/0
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_AUTH_PER_MINUTE=10
AUTH_RATE_LIMIT_DEFAULT_PER_MINUTE=60
AUTH_RATE_LIMIT_TRUST_PROXY_HEADERS=false
AUTH_RATE_LIMIT_USE_REDIS=true

# Seed users (как по кайфу)

AUTH_SEED_ADMIN_USERNAME=admin
AUTH_SEED_ADMIN_PASSWORD=admin12345
AUTH_SEED_ADMIN_EMAIL=admin@example.com

AUTH_SEED_RESEARCHER_USERNAME=researcher
AUTH_SEED_RESEARCHER_PASSWORD=researcher123
AUTH_SEED_RESEARCHER_EMAIL=researcher@example.com

AUTH_SEED_ANALYST_USERNAME=analyst
AUTH_SEED_ANALYST_PASSWORD=analyst123
AUTH_SEED_ANALYST_EMAIL=analyst@example.com

AUTH_SEED_MANAGER_USERNAME=manager
AUTH_SEED_MANAGER_PASSWORD=manager123
AUTH_SEED_MANAGER_EMAIL=manager@example.com

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_NGINX_BASIC_USER=grafana
